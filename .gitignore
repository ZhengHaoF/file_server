# ==============================
# 通用忽略规则
# ==============================

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules

# Build outputs
dist
dist-ssr
coverage
*.local

# OS
.DS_Store
Thumbs.db

# ==============================
# 后端 (server/) 特有
# ==============================

# 运行时生成的缓存和数据库
server/imgCache/
server/imgCache.db
server/logs/

# node 可执行文件（通过 build.js 打包时包含）
server/node.exe
server/node.zip

# ==============================
# Flutter (mobile/) 特有
# ==============================

# mobile/ 下有独立的 .gitignore，这里补充根级忽略
mobile/.dart_tool/
mobile/.flutter-plugins-dependencies
mobile/build/
mobile/.metadata

# ==============================
# 编辑器 / IDE
# ==============================

.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==============================
# 项目文档（可选忽略）
# ==============================

后端接口修改方案.md
前端实施文档.md
